<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrismCore.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="32,24">
        <StackPanel Spacing="4">
            <TextBlock Text="设置" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,16"/>

            <!-- 开机自启动 -->
            <TextBlock Text="启动" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,8"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16" Margin="0,2">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="开机自启动"/>
                        <TextBlock Text="登录 Windows 时自动以管理员权限启动，无需 UAC 确认" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="{x:Bind AutoStartEnabled, Mode=TwoWay}" MinWidth="0"/>
                </Grid>
            </Border>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16" Margin="0,2">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="静默启动"/>
                        <TextBlock Text="开机启动后最小化到系统托盘，不显示主窗口" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <ToggleSwitch x:Name="SilentStartToggle" Grid.Column="1" IsOn="{x:Bind SilentStartEnabled, Mode=TwoWay}" MinWidth="0"/>
                </Grid>
            </Border>

            <!-- 后台自动优化 -->
            <TextBlock Text="后台自动优化" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,8"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16" Margin="0,2">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="启用自动优化"/>
                        <TextBlock Text="内存超过阈值时自动清理" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="{x:Bind AutoOptimizeEnabled, Mode=TwoWay}" MinWidth="0"/>
                </Grid>
            </Border>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16" Margin="0,2">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="内存阈值 (%)"/>
                        <TextBlock Text="超过此值触发自动优化" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <NumberBox Grid.Column="1" Value="{x:Bind MemoryThreshold, Mode=TwoWay}"
                               Minimum="30" Maximum="95" SpinButtonPlacementMode="Compact" Width="120"/>
                </Grid>
            </Border>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16" Margin="0,2">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="自动优化间隔 (秒)"/>
                        <TextBlock Text="后台检测周期" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <NumberBox Grid.Column="1" Value="{x:Bind AutoOptimizeInterval, Mode=TwoWay}"
                               Minimum="5" Maximum="120" SpinButtonPlacementMode="Compact" Width="120"/>
                </Grid>
            </Border>

            <!-- 虚拟内存 -->
            <TextBlock Text="虚拟内存" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,16,0,8"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16" Margin="0,2">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="自动分页文件"/>
                        <TextBlock Text="内存不足时自动创建临时分页文件" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="{x:Bind AutoPagefileEnabled, Mode=TwoWay}" MinWidth="0"/>
                </Grid>
            </Border>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16" Margin="0,2">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="分页扩展阈值 (%)"/>
                        <TextBlock Text="提交比超过此值时自动扩展分页文件" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <NumberBox Grid.Column="1" Value="{x:Bind PagefileExpandThreshold, Mode=TwoWay}"
                               Minimum="50" Maximum="90" SpinButtonPlacementMode="Compact" Width="120"/>
                </Grid>
            </Border>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16" Margin="0,2">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="智能建议"/>
                        <TextBlock Text="检测到分页文件需求时弹出建议" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="{x:Bind PagefileSuggestionEnabled, Mode=TwoWay}" MinWidth="0"/>
                </Grid>
            </Border>

            <!-- 智能调度 -->
            <TextBlock Text="CPU 智能调度" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,16,0,8"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16" Margin="0,2">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="启用智能调度"/>
                        <TextBlock Text="自动约束后台高 CPU 进程" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ProBalanceEnabled, Mode=TwoWay}" MinWidth="0"/>
                </Grid>
            </Border>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16" Margin="0,2">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="系统 CPU 阈值 (%)" VerticalAlignment="Center"/>
                    <NumberBox Grid.Column="1" Value="{x:Bind ProBalanceSystemThreshold, Mode=TwoWay}"
                               Minimum="30" Maximum="95" SpinButtonPlacementMode="Compact" Width="120"/>
                </Grid>
            </Border>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16" Margin="0,2">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="进程 CPU 阈值 (%)" VerticalAlignment="Center"/>
                    <NumberBox Grid.Column="1" Value="{x:Bind ProBalanceProcessThreshold, Mode=TwoWay}"
                               Minimum="5" Maximum="50" SpinButtonPlacementMode="Compact" Width="120"/>
                </Grid>
            </Border>

            <!-- 异常检测 -->
            <TextBlock Text="异常检测" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,16,0,8"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16" Margin="0,2">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="启用异常检测"/>
                        <TextBlock Text="基于 EWMA + Z-score 检测 CPU 异常" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="{x:Bind AnomalyEnabled, Mode=TwoWay}" MinWidth="0"/>
                </Grid>
            </Border>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16" Margin="0,2">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Z-score 阈值" VerticalAlignment="Center"/>
                    <NumberBox Grid.Column="1" Value="{x:Bind AnomalyZThreshold, Mode=TwoWay}"
                               Minimum="1" Maximum="10" SmallChange="0.5"
                               SpinButtonPlacementMode="Compact" Width="120"/>
                </Grid>
            </Border>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16" Margin="0,2">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="EWMA Alpha" VerticalAlignment="Center"/>
                    <NumberBox Grid.Column="1" Value="{x:Bind AnomalyEwmaAlpha, Mode=TwoWay}"
                               Minimum="0.05" Maximum="0.95" SmallChange="0.05"
                               SpinButtonPlacementMode="Compact" Width="120"/>
                </Grid>
            </Border>

            <!-- 内存优化策略 -->
            <TextBlock Text="内存优化策略" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,16,0,8"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16" Margin="0,2">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="清理备用列表"/>
                        <TextBlock Text="释放系统缓存占用的内存" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="{x:Bind PurgeStandbyEnabled, Mode=TwoWay}" MinWidth="0"/>
                </Grid>
            </Border>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16" Margin="0,2">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="修剪工作集"/>
                        <TextBlock Text="修剪后台进程的内存工作集" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="{x:Bind TrimWorkingSetsEnabled, Mode=TwoWay}" MinWidth="0"/>
                </Grid>
            </Border>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16" Margin="0,2">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="智能分页空闲进程"/>
                        <TextBlock Text="将长时间空闲的进程分页到磁盘" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="{x:Bind PageOutIdleEnabled, Mode=TwoWay}" MinWidth="0"/>
                </Grid>
            </Border>

            <!-- 系统监控 -->
            <TextBlock Text="系统监控" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,16,0,8"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16" Margin="0,2">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="DPC/ISR 延迟监控"/>
                        <TextBlock Text="监控内核延迟，检测驱动问题" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="{x:Bind DpcMonitorEnabled, Mode=TwoWay}" MinWidth="0"/>
                </Grid>
            </Border>

            <!-- 恢复默认设置 -->
            <Button Content="恢复默认设置" Margin="0,24,0,0"
                    HorizontalAlignment="Left"
                    Click="ResetDefaults_Click"/>

        </StackPanel>
    </ScrollViewer>
</Page>
