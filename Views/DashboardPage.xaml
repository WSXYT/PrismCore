<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrismCore.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    NavigationCacheMode="Required">

    <ScrollViewer Padding="32,24">
        <StackPanel Spacing="20">

            <!-- 健康评分 + 状态 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="24">
                <Grid ColumnDefinitions="Auto,*">
                    <!-- 左侧：评分 + 智能优化 -->
                    <StackPanel HorizontalAlignment="Center" Width="140" Spacing="8">
                        <Grid Width="100" Height="100">
                            <Ellipse Width="82" Height="82"
                                     Stroke="{ThemeResource ControlStrokeColorDefaultBrush}"
                                     StrokeThickness="5" Fill="Transparent"/>
                            <ProgressRing Value="{x:Bind ViewModel.HealthScore, Mode=OneWay}"
                                          Maximum="100" Width="100" Height="100"
                                          IsIndeterminate="False"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="{x:Bind ViewModel.HealthScore, Mode=OneWay}"
                                       FontSize="28" FontWeight="Bold"/>
                            <TextBlock Text="分" FontSize="14" VerticalAlignment="Bottom" Margin="2,0,0,4"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Button Content="智能优化" Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Command="{x:Bind ViewModel.SmartOptimizeCommand}"/>
                    </StackPanel>

                    <!-- 右侧：状态提示 -->
                    <StackPanel Grid.Column="1" Margin="24,0,0,0"
                                VerticalAlignment="Top" Spacing="4">
                        <!-- 智能调度提示 -->
                        <InfoBar IsOpen="True" IsClosable="False" Severity="Informational"
                                 Visibility="{x:Bind ViewModel.ShowProBalance, Mode=OneWay}"
                                 Message="{x:Bind ViewModel.ProBalanceMessage, Mode=OneWay}"/>
                        <!-- 问题列表 -->
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.Issues, Mode=OneWay}">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <InfoBar IsOpen="True" IsClosable="False" Severity="Warning"
                                             Message="{x:Bind}" Margin="0,0,0,4"/>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                        <!-- 一切正常 -->
                        <InfoBar IsOpen="True" IsClosable="False" Severity="Success"
                                 Visibility="{x:Bind ViewModel.ShowAllClear, Mode=OneWay}"
                                 Message="看上去一切正常"/>
                        <!-- 优化状态 -->
                        <ProgressBar IsIndeterminate="True"
                                     Visibility="{x:Bind ViewModel.IsOptimizing, Mode=OneWay}"/>
                        <TextBlock Text="{x:Bind ViewModel.OptimizeStatus, Mode=OneWay}"
                                   TextWrapping="Wrap" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 实时监控指标 -->
            <TextBlock Text="实时监控" Style="{StaticResource SubtitleTextBlockStyle}"/>
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">

                <!-- 内存 -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Text="内存" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <ProgressBar Value="{x:Bind ViewModel.MemPercent, Mode=OneWay}" Maximum="100"/>
                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <Run Text="{x:Bind ViewModel.MemUsed, Mode=OneWay}"/>
                            <Run Text=" / "/>
                            <Run Text="{x:Bind ViewModel.MemTotal, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- CPU -->
                <Border Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Text="CPU" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <ProgressBar Value="{x:Bind ViewModel.CpuPercent, Mode=OneWay}" Maximum="100"/>
                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <Run Text="{x:Bind ViewModel.CpuPercent, Mode=OneWay}"/><Run Text="%"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- DPC 延迟 -->
                <Border Grid.Row="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Text="DPC 延迟" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <ProgressBar Value="{x:Bind ViewModel.DpcPercent, Mode=OneWay}" Maximum="10"/>
                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <Run Text="{x:Bind ViewModel.DpcPercent, Mode=OneWay}"/><Run Text="%"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ISR 延迟 -->
                <Border Grid.Row="1" Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Text="ISR 延迟" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <ProgressBar Value="{x:Bind ViewModel.IsrPercent, Mode=OneWay}" Maximum="10"/>
                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <Run Text="{x:Bind ViewModel.IsrPercent, Mode=OneWay}"/><Run Text="%"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 临时分页管理 -->
            <TextBlock Text="临时分页管理" Style="{StaticResource SubtitleTextBlockStyle}"/>
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16">
                <Grid>
                    <!-- 无临时分页 -->
                    <TextBlock Text="暂时还没有临时分页文件，再用用看吧~"
                               Visibility="{x:Bind ViewModel.ShowNoTempPagefile, Mode=OneWay}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <!-- 有临时分页 -->
                    <Grid Visibility="{x:Bind ViewModel.HasTempPagefile, Mode=OneWay}"
                          ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <TextBlock Text="{x:Bind ViewModel.TempPagefileDisplay, Mode=OneWay}"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="增加到默认分页"
                                Visibility="{x:Bind ViewModel.ShowAddToDefault, Mode=OneWay}"
                                Command="{x:Bind ViewModel.AddToDefaultPagefileCommand}"/>
                        <Button Grid.Column="2" Content="立即重启清除"
                                Command="{x:Bind ViewModel.RequestRebootClearCommand}"/>
                    </Grid>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
