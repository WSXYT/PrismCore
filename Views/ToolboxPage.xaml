<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrismCore.Views.ToolboxPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="32,24">
        <StackPanel Spacing="16">
            <TextBlock Text="网络工具箱" Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="常用网络修复工具" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <ProgressBar x:Name="ProgressBar" IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsRunning, Mode=OneWay}"/>
            <TextBlock x:Name="StatusText" Text="{x:Bind ViewModel.ToolStatus, Mode=OneWay}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <!-- DNS 刷新 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <FontIcon Glyph="&#xE774;" FontSize="24" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Margin="16,0" VerticalAlignment="Center">
                        <TextBlock Text="刷新 DNS 缓存" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock Text="清除本地 DNS 解析缓存，解决域名解析问题"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="执行" Width="80"
                            Command="{x:Bind ViewModel.RunDnsCommand}"/>
                </Grid>
            </Border>

            <!-- Winsock 重置 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <FontIcon Glyph="&#xE774;" FontSize="24" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Margin="16,0" VerticalAlignment="Center">
                        <TextBlock Text="重置 Winsock" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock Text="修复网络套接字错误，需重启生效"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="执行" Width="80"
                            Command="{x:Bind ViewModel.RunWinsockCommand}"/>
                </Grid>
            </Border>

            <!-- TCP/IP 重置 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <FontIcon Glyph="&#xE774;" FontSize="24" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Margin="16,0" VerticalAlignment="Center">
                        <TextBlock Text="重置 TCP/IP" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock Text="重置网络协议栈，修复连接异常，需重启生效"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="执行" Width="80"
                            Command="{x:Bind ViewModel.RunTcpCommand}"/>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
