<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrismCore.Views.UpdatePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="32,24">
        <StackPanel Spacing="16">
            <TextBlock Text="软件更新" Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="检查并安装最新版本（默认仅稳定版，不接收预发布）"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <!-- 版本信息 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Text="当前版本：" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.CurrentVersion, Mode=OneWay}"/>
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Text="最新版本：" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.LatestVersion, Mode=OneWay}"/>
                    </Grid>
                    <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- 操作按钮 -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="检查更新"
                        Command="{x:Bind ViewModel.CheckForUpdateCommand}"/>
                <Button Content="立即更新" Style="{StaticResource AccentButtonStyle}"
                        Command="{x:Bind ViewModel.UpdateCommand}"
                        IsEnabled="{x:Bind ViewModel.HasUpdate, Mode=OneWay}"/>
            </StackPanel>

            <ProgressBar Value="{x:Bind ViewModel.UpdateProgress, Mode=OneWay}"
                         Maximum="100"
                         Visibility="{x:Bind ViewModel.IsUpdating, Mode=OneWay}"/>

            <!-- 更新设置 -->
            <TextBlock Text="自动更新设置" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0"/>

            <RadioButtons SelectedIndex="{x:Bind ViewModel.SelectedUpdateMode, Mode=TwoWay}">
                <RadioButton Content="不自动检查更新"/>
                <RadioButton Content="仅检查更新（启动时检查，有更新时通知）"/>
                <RadioButton Content="检查更新后自动安装"/>
            </RadioButtons>
        </StackPanel>
    </ScrollViewer>
</Page>
