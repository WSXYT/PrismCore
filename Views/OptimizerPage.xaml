<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrismCore.Views.OptimizerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="32,24">
        <StackPanel Spacing="20">
            <TextBlock Text="系统加速" Style="{StaticResource TitleTextBlockStyle}"/>

            <!-- 内存状态卡片 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="内存状态" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock VerticalAlignment="Center">
                            <Run Text="已用 "/><Run Text="{x:Bind ViewModel.MemUsed, Mode=OneWay}"/>
                            <Run Text=" / 共 "/><Run Text="{x:Bind ViewModel.MemTotal, Mode=OneWay}"/>
                            <Run Text="  可用 "/><Run Text="{x:Bind ViewModel.MemAvailable, Mode=OneWay}"/>
                        </TextBlock>
                        <Button Grid.Column="1" Content="刷新"
                                Command="{x:Bind ViewModel.RefreshMemoryCommand}"/>
                    </Grid>
                    <ProgressBar Value="{x:Bind ViewModel.MemPercent, Mode=OneWay}" Maximum="100"/>
                    <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        <Run Text="提交比: "/><Run Text="{x:Bind ViewModel.CommitRatio, Mode=OneWay}"/><Run Text="%"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- 优化操作 -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="智能优化" Style="{StaticResource AccentButtonStyle}"
                        Command="{x:Bind ViewModel.OptimizeMemoryCommand}"/>
            </StackPanel>
            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsOptimizing, Mode=OneWay}"/>
            <TextBlock Text="{x:Bind ViewModel.OptimizeStatus, Mode=OneWay}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <!-- 启动项管理 -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                <TextBlock Text="启动项管理" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="刷新" Command="{x:Bind ViewModel.RefreshStartupCommand}"/>
            </Grid>
            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsLoadingStartup, Mode=OneWay}"/>
            <ListView ItemsSource="{x:Bind ViewModel.StartupItems, Mode=OneWay}"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="8,6" ColumnDefinitions="*,Auto,Auto">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}"/>
                                <TextBlock Text="{Binding Source}" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="12,0"
                                       Text="{Binding Enabled}" FontSize="12"/>
                            <ToggleSwitch Grid.Column="2" IsOn="{Binding Enabled, Mode=OneWay}"
                                          Toggled="OnStartupToggled" MinWidth="0"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- 进程管理 -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                <TextBlock Text="进程管理" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="刷新" Command="{x:Bind ViewModel.RefreshProcessesCommand}"/>
            </Grid>
            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsLoadingProcesses, Mode=OneWay}"/>
            <ListView ItemsSource="{x:Bind ViewModel.Processes, Mode=OneWay}"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="8,4" ColumnDefinitions="60,*,80,Auto">
                            <TextBlock Text="{Binding Pid}" VerticalAlignment="Center" FontSize="12"/>
                            <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="12">
                                <Run Text="{Binding MemoryMb}"/><Run Text=" MB"/>
                            </TextBlock>
                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4">
                                <Button Content="↑" Width="32" FontSize="12"
                                        Tag="{Binding Pid}" Click="OnBoost"/>
                                <Button Content="↓" Width="32" FontSize="12"
                                        Tag="{Binding Pid}" Click="OnThrottle"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </ScrollViewer>
</Page>
