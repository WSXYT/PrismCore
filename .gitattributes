# 自动规范化文本文件的行尾
* text=auto

# Shell 脚本始终使用 LF 行尾（防止 Windows checkout 转为 CRLF 导致 CI 失败）
*.sh text eol=lf

# Windows 批处理文件始终使用 CRLF 行尾
*.cmd text eol=crlf
*.bat text eol=crlf

# C# / .NET 项目文件
*.cs text diff=csharp
*.csproj text
*.sln text eol=crlf
*.xaml text

# 配置文件
*.json text
*.xml text
*.yml text
*.yaml text
*.md text
*.txt text

# 二进制文件（不做行尾转换）
*.png binary
*.ico binary
*.pfx binary
*.snk binary
